{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Caplia API",
  "description": "Read deals, submit decks, poll async results. Public REST API for the Caplia venture platform.",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "/api-reference/openapi.json"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Caplia",
        "href": "https://www.caplia.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://investor.caplia.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "mcp"]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/caplia"
    }
  }
