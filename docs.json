{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Caplia API",
  "description": "Programmatic access to Caplia - the Venture API for investors reading deal flow, and the Founder API for founders improving their own company.",
  "colors": {
    "primary": "#344365",
    "light": "#02A0FD",
    "dark": "#1F2940"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Venture API",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Getting started",
            "pages": [
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/mcp",
              "integrations/venture-form-widget",
              "integrations/caplia-connector"
            ]
          },
          {
            "group": "API reference",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "/api-reference/openapi.json"
          }
        ]
      },
      {
        "tab": "Founder API",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "founder/index",
              "founder/quickstart",
              "founder/authentication"
            ]
          },
          {
            "group": "Improve your deck",
            "pages": [
              "founder/deck-loop"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "founder/mcp"
            ]
          },
          {
            "group": "API reference",
            "pages": [
              "founder/api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "/founder/api-reference/openapi.json"
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Caplia",
        "href": "https://www.caplia.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get an API key",
      "href": "https://investor.caplia.ai/settings/api-keys"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "mcp"]
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/caplia-ai/"
    }
  }
}
